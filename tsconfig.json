{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "resolveJsonModule": true,
    "declaration": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "typeRoots": [                                       /* Specify multiple folders that act like `./node_modules/@types`. */
      "./node_modules/@types",
      "./src/@types"
    ]
  },
  "include": ["src/**/*", "@types"],
  "exclude": ["node_modules", "dist"]
}
