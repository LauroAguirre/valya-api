# ── MySQL (usado pelo docker-compose) ──────────────────────────────────────────
MYSQL_ROOT_PASSWORD=troque-pela-senha-root
MYSQL_DATABASE=valya
MYSQL_USER=valya
MYSQL_PASSWORD=troque-pela-senha-do-usuario

# ── API ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# Gerado automaticamente pelo docker-compose a partir das vars MySQL acima.
# Não precisa alterar se usar o docker-compose.
DATABASE_URL=mysql://valya:troque-pela-senha-do-usuario@mysql:3306/valya

JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

FRONTEND_URL=https://seudominio.com.br

# ── OpenAI ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Evolution API ──────────────────────────────────────────────────────────────
# Use o nome do container ou IP/domínio público, dependendo de como subiu o Evolution
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=sua-api-key-do-evolution

# URL pública que o Evolution usará para enviar webhooks para esta API
WEBHOOK_URL=https://api.seudominio.com.br

# ── Asaas ──────────────────────────────────────────────────────────────────────
ASAAS_API_URL=https://api.asaas.com/api/v3
ASAAS_API_KEY=sua-chave-asaas
ASAAS_WEBHOOK_SECRET=seu-segredo-webhook-asaas

# ── SMTP ───────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu@email.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=Valya <noreply@seudominio.com.br>

# ── OAuth ──────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
